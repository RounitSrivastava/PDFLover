# External Executables & Tool Paths
# ----------------------------------
# (Optional) Path to the yt-dlp executable.
# Default (Windows): Falls back to C:\yt-dlp\yt-dlp.exe if it exists, otherwise "yt-dlp"
# Default (Other): "yt-dlp"
# YT_DLP_PATH=/usr/local/bin/yt-dlp

# (Optional) Path to the ffmpeg executable or binary directory.
# Default (Windows): Falls back to C:\ffmpeg\ffmpeg-8.0.1-essentials_build\bin if it exists, otherwise empty (relying on PATH)
# Default (Other): Empty (relying on PATH)
# FFMPEG_PATH=/usr/local/bin

# (Optional) Use a custom cookies file (e.g. cookies.txt) for yt-dlp to bypass rate limits or login walls.
# YT_DLP_COOKIES_FILE=/path/to/cookies.txt

# (Optional) Extraction of cookies from a specific browser for yt-dlp.
# YT_DLP_COOKIES_BROWSER=firefox

# (Optional) Path to the LibreOffice soffice executable.
# Default (Windows): Falls back to "C:\Program Files\LibreOffice\program\soffice.exe" if it exists, otherwise "soffice"
# Default (Other): "soffice"
# SOFFICE_PATH=/usr/bin/soffice

# (Optional) Python interpreter command.
# Default: "python" (can be set to "python3" for Linux production environments)
# PYTHON_PATH=python3
